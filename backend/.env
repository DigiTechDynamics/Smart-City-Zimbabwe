# ─── Database ───────────────────────────────────────────────────────────────
# SQLite (default local dev – no setup required)
DATABASE_URL=sqlite:///./smart_city.db

# Uncomment and fill in to use PostgreSQL instead:
# DATABASE_URL=postgresql://user:password@localhost:5432/smart_city_db

# ─── Google Generative AI (Gemini) ──────────────────────────────────────────
# Required: Get your key from https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here

# ─── App Security ────────────────────────────────────────────────────────────
SECRET_KEY=smart-city-zimbabwe-super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ─── CORS / Frontend Origin ──────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
